#!/usr/bin/env bash
# gstack setup-orchestrator — universal installer for gstack + orchestration layer
# Safe to re-run (idempotent). Works on macOS, Linux, WSL.
set -e

GSTACK_REPO="https://github.com/fullya99/gstack.git"
SKILLS_DIR="$HOME/.claude/skills"
GSTACK_DIR="$SKILLS_DIR/gstack"
PLUGINS_DIR="$HOME/.claude/plugins/local"

# ─── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { echo -e "${BLUE}→${NC} $*"; }
ok()    { echo -e "${GREEN}✓${NC} $*"; }
warn()  { echo -e "${YELLOW}⚠${NC} $*"; }
fail()  { echo -e "${RED}✗${NC} $*" >&2; }

# ─── 1. Detect OS ────────────────────────────────────────────────────────────
detect_os() {
  case "$(uname -s)" in
    Darwin) echo "macos" ;;
    Linux)
      if grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
        echo "wsl"
      else
        echo "linux"
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *) echo "unknown" ;;
  esac
}

OS=$(detect_os)
info "Detected OS: $OS"

# ─── 2. Install Bun if missing ───────────────────────────────────────────────
if ! command -v bun >/dev/null 2>&1; then
  info "Installing Bun..."
  curl -fsSL https://bun.sh/install | bash
  # Source the new PATH
  export BUN_INSTALL="$HOME/.bun"
  export PATH="$BUN_INSTALL/bin:$PATH"
  if command -v bun >/dev/null 2>&1; then
    ok "Bun installed: $(bun --version)"
  else
    fail "Bun installation failed"
    exit 1
  fi
else
  ok "Bun found: $(bun --version)"
fi

# ─── 3. Install Git if missing ───────────────────────────────────────────────
if ! command -v git >/dev/null 2>&1; then
  info "Installing Git..."
  case "$OS" in
    macos)
      xcode-select --install 2>/dev/null || true
      warn "Xcode CLT install triggered — re-run this script after it completes"
      exit 0
      ;;
    linux|wsl)
      if command -v apt-get >/dev/null 2>&1; then
        sudo apt-get update -qq && sudo apt-get install -y -qq git
      elif command -v dnf >/dev/null 2>&1; then
        sudo dnf install -y git
      elif command -v pacman >/dev/null 2>&1; then
        sudo pacman -S --noconfirm git
      else
        fail "Cannot install git — please install it manually"
        exit 1
      fi
      ;;
    *)
      fail "Cannot install git on $OS — please install it manually"
      exit 1
      ;;
  esac
  ok "Git installed"
else
  ok "Git found: $(git --version | head -1)"
fi

# ─── 4. Clone or update gstack ───────────────────────────────────────────────
mkdir -p "$SKILLS_DIR"

if [ -d "$GSTACK_DIR/.git" ]; then
  info "Updating gstack..."
  (cd "$GSTACK_DIR" && git fetch origin && git reset --hard origin/main)
  ok "gstack updated to latest"
else
  if [ -d "$GSTACK_DIR" ]; then
    warn "Removing non-git gstack directory"
    rm -rf "$GSTACK_DIR"
  fi
  info "Cloning gstack..."
  git clone "$GSTACK_REPO" "$GSTACK_DIR"
  ok "gstack cloned"
fi

# ─── 5. Install system deps (Linux) ──────────────────────────────────────────
if [ "$OS" = "linux" ] || [ "$OS" = "wsl" ]; then
  info "Installing Playwright system dependencies..."
  (cd "$GSTACK_DIR" && bunx playwright install-deps chromium 2>/dev/null) || {
    warn "Could not auto-install system deps — you may need: sudo apt-get install libgbm1 libnss3 libatk-bridge2.0-0 libdrm2 libxcomposite1 libxdamage1 libxrandr2 libgbm-dev libasound2"
  }
fi

# ─── 6. Run existing gstack setup ────────────────────────────────────────────
info "Running gstack setup (build + skill registration)..."
(cd "$GSTACK_DIR" && chmod +x setup && ./setup)

# ─── 7. Register plugin ──────────────────────────────────────────────────────
if [ -f "$GSTACK_DIR/.claude-plugin/plugin.json" ]; then
  mkdir -p "$PLUGINS_DIR"
  ln -snf "$GSTACK_DIR" "$PLUGINS_DIR/gstack-orchestrator"
  ok "Plugin registered: gstack-orchestrator → $GSTACK_DIR"
else
  warn "Plugin manifest not found — skipping plugin registration"
fi

# ─── 8. Verification ─────────────────────────────────────────────────────────
echo ""
echo "═══════════════════════════════════════"
echo "  gstack + orchestrator verification"
echo "═══════════════════════════════════════"

PASS=0
TOTAL=0

check() {
  TOTAL=$((TOTAL + 1))
  if eval "$2" >/dev/null 2>&1; then
    ok "$1"
    PASS=$((PASS + 1))
  else
    fail "$1"
  fi
}

check "Browse binary"        "test -x '$GSTACK_DIR/browse/dist/browse'"
check "Chromium (Playwright)" "cd '$GSTACK_DIR' && bun --eval 'import { chromium } from \"playwright\"; const b = await chromium.launch(); await b.close();'"
check "Plugin manifest"      "test -f '$GSTACK_DIR/.claude-plugin/plugin.json'"
check "Plugin symlink"       "test -L '$PLUGINS_DIR/gstack-orchestrator'"

for skill in browse plan-ceo-review plan-eng-review review ship qa setup-browser-cookies retro; do
  check "Skill: $skill" "test -L '$SKILLS_DIR/$skill' || test -d '$SKILLS_DIR/$skill'"
done

echo ""
echo "═══════════════════════════════════════"
if [ "$PASS" -eq "$TOTAL" ]; then
  ok "All checks passed ($PASS/$TOTAL)"
else
  warn "$PASS/$TOTAL checks passed"
fi
echo "═══════════════════════════════════════"
echo ""
info "Usage:"
echo "  /health-check    — verify installation anytime"
echo "  /deploy          — ship + QA verify"
echo "  /full-cycle      — plan → review → ship → QA"
echo "  Ask: 'orchestrate this feature' to trigger the orchestrator agent"
